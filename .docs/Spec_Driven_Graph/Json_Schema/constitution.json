{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "constitution-json-fields",
  "title": "Constitution JSON Fields Schema",
  "type": "object",
  "properties": {
    "articles": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "article_id": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "coding_standard",
              "architectural_principle",
              "naming_convention",
              "team_convention",
              "process_rule",
              "security_policy"
            ]
          },
          "title": { "type": "string" },
          "statement": { "type": "string" },
          "rationale": { "type": "string" },
          "enforcement": {
            "type": "string",
            "enum": ["automated", "manual", "advisory"]
          },
          "applies_to": {
            "type": "array",
            "items": { "type": "string" }
          },
          "effective_date": { "type": "string", "format": "date" },
          "supersedes": { "type": "string" }
        },
        "required": ["article_id", "category", "title", "statement", "rationale", "enforcement"],
        "additionalProperties": false
      }
    }
  },
  "required": ["articles"],
  "additionalProperties": false
}
