{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Data Structure JSON Fields",
  "type": "object",
  "properties": {
    "fields": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "type": { "type": "string", "enum": ["UUID", "STRING", "INTEGER", "FLOAT", "BOOLEAN", "DATETIME", "ENUM"] },
          "required": { "type": "boolean" },
          "unique": { "type": "boolean" },
          "default": { "type": ["string", "number", "boolean", "null"] },
          "description": { "type": "string" },
          "validation": {
            "type": "object",
            "properties": {
              "min": { "type": "number" },
              "max": { "type": "number" },
              "pattern": { "type": "string" },
              "enum": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "required": ["name", "type", "required"]
      }
    },
    "relationships": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["belongs_to", "has_many", "has_one", "many_to_many"] },
          "target_entity": { "type": "string" },
          "via_field": { "type": "string" },
          "description": { "type": "string" }
        },
        "required": ["type", "target_entity", "via_field", "description"]
      }
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "type": { "type": "string", "enum": ["unique", "check", "primary_key"] },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          },
          "name": { "type": "string" }
        },
        "required": ["type", "fields"]
      }
    },
    "indexes": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "fields": {
            "type": "array",
            "items": { "type": "string" }
          },
          "unique": { "type": "boolean" }
        },
        "required": ["name", "fields", "unique"]
      }
    }
  },
  "required": ["fields"]
}
